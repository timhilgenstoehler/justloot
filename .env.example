# Supabase (required for auth + cloud saves + leaderboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Optional alias (Supabase dashboard may label this "publishable key")
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Web (Next.js) — same values, NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Marketing site
NEXT_PUBLIC_SITE_URL=https://justloot.vercel.app
